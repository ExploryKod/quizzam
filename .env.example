# Environnement Node
# Local / nx serve : development (valeur par défaut si absent).
# Image Docker production : NODE_ENV=production est défini dans docker/Dockerfile (stage build + image finale).
NODE_ENV=development

# Configuration Base de Données
# Par défaut : nx serve ou Mongo sur ta machine (localhost) sinon adapter la valeur 
# Si usage de docker qui conteneurise mongo + api : mongodb://mongodb:27017/quizapp).
DATABASE_URL=mongodb://localhost:27017/quizapp
# Mongo express est disponible sur le port 8086 si usage de docker avec ces credentials : mongodb://admin:pass@localhost:27017/db?ssl=false
# MONGODB : docker/compose.dev.yaml peut démarrer MongoDB + mongo-express (profil « mongodb »).

# IN-MEMORY : pas de Mongo au démarrage (recommandé pour nx serve sans Docker).
# MONGODB : nécessite DATABASE_URL + Mongo joignable.
DATABASE_NAME=IN-MEMORY  # Options: MONGODB, FIREBASE, IN-MEMORY

# Configuration Serveur
PORT=3000
GLOBAL_PREFIX=api

# CORS: "*" (insécure) ou liste séparée par des virgules (origines exactes, sans path)
CORS_ORIGIN=*
# CORS_ORIGIN=https://space-cruising.netlify.app,http://localhost:4200

# Configuration Authentification
AUTH_TYPE=JWT  # Options: JWT, FIREBASE
JWT_SECRET=votre-cle-secrete-changez-en-production

# Firebase (uniquement si utilisation de Firebase)
# FIREBASE_KEY_PATH=src/assets/quizzam-firebase-key.json
